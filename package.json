{
  "name": "up2speed",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:tauri": "tauri dev",
    "build": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "build:tauri": "tauri build",
    "preview": "vite preview",
    "deploy": "vercel deploy --prod",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vercel/node": "^5.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.0",
    "vite": "^7.3.1"
  }
}
